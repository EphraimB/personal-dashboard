# ==============================================================================
# PhotoPrism Configuration Environment File
# ==============================================================================
# Copy this file to '.env' and modify the values as needed.
# Reference: https://docs.photoprism.app/getting-started/docker-compose/
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Core Service Settings
# ------------------------------------------------------------------------------
# Security Warning: Change the admin password! It must be at least 8 characters.
PHOTOPRISM_ADMIN_PASSWORD=insecure-default-change-me

# The port PhotoPrism will listen on on your host machine.
PHOTOPRISM_HTTP_PORT=2342

# Site URL for generating sharing links. Can be an IP or a domain.
PHOTOPRISM_SITE_URL=http://localhost:2342/

# ------------------------------------------------------------------------------
# 2. Host Storage Paths
# ------------------------------------------------------------------------------
# IMPORTANT: It is highly recommended to use an SSD connected via USB 3.0
# instead of an SD card for the originals and storage directories, as database
# access and thumbnail caching require high I/O performance.

# Path to your photo library (Originals). Can be absolute or relative.
PHOTOPRISM_ORIGINALS_PATH=~/Pictures

# Path for metadata storage (database, cache, thumbnails, etc.).
# DO NOT put SQLite database/storage on network mounts (NFS/SMB) due to file locking!
PHOTOPRISM_STORAGE_PATH=./storage

# Optional: Path for importing files into the originals folder.
PHOTOPRISM_IMPORT_PATH=./import

# Optional: Path for database backups and index exports.
PHOTOPRISM_BACKUP_PATH=./backup

# ------------------------------------------------------------------------------
# 3. Raspberry Pi & Resource Tuning
# ------------------------------------------------------------------------------
# Limit the number of concurrent indexer worker threads.
# For Raspberry Pi, this is CRITICAL to prevent out-of-memory crashes:
# - Raspberry Pi 4/5 (4GB or 8GB): Set to 2
# - Raspberry Pi 4 (2GB): Set to 1
# - Default (blank): Automatic based on CPU count (can freeze your Pi!)
PHOTOPRISM_WORKERS=2

# Disable AI features if you want to optimize for pure performance / lower RAM:
PHOTOPRISM_DISABLE_FACES=false
PHOTOPRISM_DISABLE_CLASSIFICATION=false

# FFMPEG Video Encoder selection (uncomment if you wish to configure hardware acceleration)
# NOTE: Hardware acceleration is experimental and depends on OS version/Pi model.
# PHOTOPRISM_FFMPEG_ENCODER=raspberry

# ------------------------------------------------------------------------------
# 4. Database Selection (SQLite vs MariaDB/MySQL)
# ------------------------------------------------------------------------------
# PhotoPrism defaults to SQLite (stored in storage/index.db) if no database is specified.
# SQLite is highly recommended for Raspberry Pi due to its lightweight footprint (no extra container).
# Set to 'mysql' if you enable the MariaDB service in compose.yaml.
PHOTOPRISM_DATABASE_DRIVER=sqlite

# The fields below are only used if PHOTOPRISM_DATABASE_DRIVER is set to 'mysql'
PHOTOPRISM_DATABASE_SERVER=mariadb:3306
PHOTOPRISM_DATABASE_NAME=photoprism
PHOTOPRISM_DATABASE_USER=photoprism
PHOTOPRISM_DATABASE_PASSWORD=photoprism-db-password-change-me
MARIADB_ROOT_PASSWORD=mariadb-root-password-change-me
